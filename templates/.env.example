# Required: Gemini API key for proxy -> Gemini HTTPS
GEMINI_API_KEY=PUT_YOUR_GEMINI_API_KEY_HERE

# Optional: Google Apps Script Web App URL for Google Doc logging / Drive read
GOOGLE_DOC_WEBHOOK_URL=

# Optional: shared token (must match WEBHOOK_TOKEN in Code.gs)
GOOGLE_DOC_WEBHOOK_TOKEN=

# Optional: local transcript backup
CHAT_LOG_JSONL=chat_log.jsonl

# Proxy listener settings
PROXY_HOST=0.0.0.0
PROXY_PORT=8080
PROXY_PATH=/gemini

# Default Gemini model (used when client request does not specify model)
PROXY_MODEL=gemini-2.5-flash
